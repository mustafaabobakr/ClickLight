{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"jsx": "react-jsx",
		"declaration": true,
		"outDir": "dist",
		"strict": true,
		"moduleResolution": "bundler",
		"module": "esnext",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"noEmit": false
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
